#!/bin/sh
# Run TreeAnnotator from anywhere.
# Requires: mvn package -Dmaven.test.skip=true (run once in the beast3 repo)

BEAST3="$(cd "$(dirname "$0")/.." && pwd)"
java --module-path "$BEAST3/beast-fx/target/beast-fx-2.8.0-SNAPSHOT.jar:$BEAST3/beast-fx/target/lib" \
     -m beast.fx/beastfx.app.treeannotator.TreeAnnotator "$@"
