#!/bin/sh
# Run BEAST3 (headless, no JavaFX) from anywhere.
# Requires: mvn package -Dmaven.test.skip=true (run once in the beast3 repo)

BEAST3="$(cd "$(dirname "$0")/.." && pwd)"
java --module-path "$BEAST3/beast-base/target/beast-base-2.8.0-SNAPSHOT.jar:$BEAST3/beast-base/target/lib" \
     -m beast.base/beast.base.minimal.BeastMain "$@"
