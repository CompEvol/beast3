    <plate spec="util.Plate" var="n" range=".p1,.p2,.p3">
        <!-- The HKY substitution model (Hasegawa, Kishino & Yano, 1985)             -->
        <input spec="beast.base.spec.evolution.substitutionmodel.HKY" id="hky$(n)" kappa="@hky.kappa$(n)">
            <frequencies id="freqs$(n)" spec="beast.base.spec.evolution.substitutionmodel.Frequencies" data="@alignment$(n)"/>
        </input>

        <!-- site model                                                              -->
        <input spec="beast.base.spec.evolution.sitemodel.SiteModel" id="siteModel$(n)" substModel="@hky$(n)"/>

        <input spec="beast.base.spec.evolution.likelihood.TreeLikelihood" id="treeLikelihood$(n)" data="@alignment$(n)" tree="@tree" siteModel="@siteModel$(n)"/>

        <parameter id="hky.kappa$(n)" value="1.0" spec="beast.base.spec.inference.parameter.RealScalarParam" domain="PositiveReal"/>
    </plate>

    <tree spec="beast.base.spec.evolution.tree.ClusterTree" id="tree" clusterType="upgma" taxa="@alignment.p1"/>

    <run spec="MCMC" id="mcmc" chainLength="$(chainLength=10000000)">
        <state storeEvery="100000">
            <stateNode idref="hky.kappa.p1"/>
            <stateNode idref="hky.kappa.p2"/>
            <stateNode idref="hky.kappa.p3"/>
            <stateNode idref="tree"/>
        </state>

        <distribution spec="CompoundDistribution" id="likelihood">
            <plate var="n" range=".p1,.p2,.p3">
                <distribution id="likelihood$(n)" idref="treeLikelihood$(n)"/>
            </plate>
        </distribution>
    
        <plate var="n" range=".p1,.p2,.p3">
            <operator id="kappaScaler$(n)" scaleFactor="0.5" weight="1" parameter="@hky.kappa$(n)" spec="beast.base.spec.inference.operator.ScaleOperator"/>
        </plate>
        <operator id="treeScaler" scaleFactor="0.5" weight="1" tree="@tree" spec="beast.base.spec.evolution.operator.ScaleTreeOperator"/>
        <operator weight="10" tree="@tree" spec="beast.base.evolution.operator.Uniform"/>
        <operator spec="beast.base.evolution.operator.kernel.BactrianSubtreeSlide" weight="5" size="1.0" tree="@tree"/>
        <operator id="narrow" spec="Exchange" isNarrow="true" weight="1" tree="@tree"/>
        <operator id="wide" spec="Exchange" isNarrow="false" weight="1" tree="@tree"/>
        <operator spec="WilsonBalding" weight="1" tree="@tree"/>

        <logger logEvery="10000" fileName="test.$(seed).log">
	        <model idref="likelihood"/>
            <log idref="likelihood"/>
            <plate var="n" range=".p1,.p2,.p3">
                <log idref="hky.kappa$(n)"/>
            </plate>
            <log spec="beast.base.evolution.tree.TreeStatLogger"><tree idref="tree"/></log>
        </logger>
        <logger logEvery="10000" fileName="test.$(seed).trees">
            <log idref="tree"/>
        </logger>
        <logger logEvery="10000">
	        <model idref="likelihood"/>
            <log idref="likelihood"/>
    	    <ESS spec="beast.base.spec.inference.util.ESS" name="log" arg="@likelihood"/>
            <plate var="n" range=".p1,.p2,.p3">
                <log idref="hky.kappa$(n)"/>
        	    <ESS spec="beast.base.spec.inference.util.ESS" name="log" arg="@hky.kappa$(n)"/>
            </plate>
        </logger>

    </run>

</beast>
